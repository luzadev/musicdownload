{
  "name": "musictools-license-server",
  "version": "0.1.0",
  "private": true,
  "description": "License + update API for MusicTools (Cloudflare Workers + D1)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create musictools-licenses",
    "db:migrate:local": "wrangler d1 migrations apply musictools-licenses --local",
    "db:migrate:prod": "wrangler d1 migrations apply musictools-licenses --remote",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.95.0"
  }
}
